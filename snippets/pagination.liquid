{% comment %}
  Usage: {% render 'pagination', paginate: paginate %}
  Must be called with an explicit `paginate:` param since {% render %}
  does not inherit variables from the calling template - the `paginate`
  object created by {% paginate %} in the parent scope is NOT visible
  here unless passed in.
{% endcomment %}

{% if paginate.pages > 1 %}
    <nav role="navigation" aria-label="Pagination" class="flex justify-center items-center my-8 gap-1">
        {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="border border-gray-600 text-gray-600 hover:bg-gray-600 hover:text-white px-8 py-3 mx-1 rounded-sm font-medium">Previous</a>
        {% endif %}

        {% for part in paginate.parts %}
          {% if part.is_link %}
            <a href="{{ part.url }}" class="border border-gray-300 text-gray-600 hover:bg-gray-600 hover:text-white px-4 py-2 mx-1 rounded-sm font-medium">{{ part.title }}</a>
          {% else %}
            <span class="bg-gray-600 text-white px-4 py-2 mx-1 rounded-sm font-medium">{{ part.title }}</span>
          {% endif %}
        {% endfor %}

        {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="border border-gray-600 text-gray-600 hover:bg-gray-600 hover:text-white px-8 py-3 mx-1 rounded-sm font-medium">Next</a>
        {% endif %}
    </nav>
{% endif %}

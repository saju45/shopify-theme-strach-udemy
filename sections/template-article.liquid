
<article class="py-8">
    {% for item in section.blocks %}
    
    {% case item.type %}
        {% when "article_title" %}
             <div class="flex items-center justify-center">
                <div class="max-w-7xl text-center">
                    <a href="{{blog.url}}" class="text-base uppercase text-gray-500 hover:text-gray-900 font-bold">{{blog.title}}</a>
                    <h1 class="text-4xl md:text-6xl font-medium">{{article.title}}</h1>
                </div>

             </div>
        {% when "article_author" %}


            <div class="flex items-center justify-center">
                <div class="max-w-7xl text-center">
                      {% if section.settings.enable_author %}
                <small>{{article.author}}</small>
            {% endif %}
                </div>

             </div>

          
        {% when "article_date" %}

            <div class="flex items-center justify-center">
                <div class="max-w-7xl text-center">
                    {% if section.settings.enable_date %}
                        <small>{{article.published_at | date: "%B %d, %Y"}}</small>
                    {% endif %}
                </div>
            </div>
        {% when "article_image" %}

            <div class="max-w-7xl bg-blue-100 rounded-lg mx-2 md:mx-auto overflow-hidden my-4 ">  
                
            {% if section.settings.enable_image %}
                <img  class="w-full h-80 md:h-96 object-cover object-center p-5" src="{{article.image | img_url: 'medium'}}" alt="{{article.title}}">

                {% else %}
                    {%  assign  placholder_image = 'lifestyle-2' %} 
                    {{placholder_image | placeholder_svg_tag: 'w-full h-80 md:h-96 object-cover object-center p-5' }}
            {% endif %}
            </div>


        {% when "article_content" %}

            {% if section.settings.enable_content %}
                <div class="flex items-center justify-center">
                    <div class="max-w-7xl text-center">
                    {{article.content}}

                    </div>
                </div>
            {% endif %}
    {% endcase %}
    
{% endfor %}

</article>



<h1>
{{article.title}}
</h1>

{% if section.settings.enable_author %}
  <small>{{article.author}}</small>
{% endif %}

{% if section.settings.enable_date %}
  <small>{{article.published_at | date: "%B %d, %Y"}}</small>
{% endif %}

{% if section.settings.enable_image %}
  <img src="{{article.image | img_url: 'medium'}}" alt="{{article.title}}">
{% endif %}

{% if section.settings.enable_content %}
  <div class="article-content">
    {{article.content}}
  </div>
{% endif %}





{%  schema  %} 
{
    "name": "Template Article",
     "settings": [
        {
            "type": "checkbox",
            "id": "enable_author",
             "default": true,
             "label": "Display Author name "
            
        },
        {
            "type": "checkbox",
            "id": "enable_date",
             "default": true,
             "label": "Display Published Date"
            
        },
        {
            "type": "checkbox",
            "id": "enable_image",
             "default": true,
             "label": "Display Article Image"
            
        },
        {
            "type": "checkbox",
            "id": "enable_content",
             "default": true,
             "label": "Display Article Content"
            
        }
     ],
     "blocks": [
        {
            "type": "article_title",
            "name": " Title ",
            "limit": 1
        },
        {
            "type": "article_author",
            "name": " Author ",
            "limit": 1
        },
        {
            "type": "article_date",
            "name": " Published Date ",
            "limit": 1
        },
        {
            "type": "article_image",
            "name": " Article Image ",
            "limit": 1
        },
        {
            "type": "article_content",
            "name": " Article Content ",
            "limit": 1
        }
     ]
}
{% endschema %}   